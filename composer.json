{
  "name": "ridwans2/filamod",
  "description": "Organize your Filament Code into modules using nwidart/laravel-modules",
  "keywords": [
    "ridwans2",
    "laravel",
    "FilamentModules",
    "filament"
  ],
  "homepage": "https://github.com/ridwans2/filamod",
  "support": {
    "issues": "https://github.com/ridwans2/filamod/issues",
    "source": "https://github.com/ridwans2/filamod"
  },
  "license": "MIT",
  "authors": [
    {
      "name": "Ridwan Setiawan",
      "email": "penyair@gmail.com",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.3",
    "filament/filament": "^5.1",
    "nwidart/laravel-modules": "^12.0",
    "spatie/laravel-package-tools": "^1.15.0"
  },
  "require-dev": {
  
  },
  "autoload": {
    "psr-4": {
      "Coolsam\\Modules\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Coolsam\\Modules\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "@clear",
      "@prepare",
 
    ],
   
   
   
   
    "serve": [
      "Composer\\Config::disableProcessTimeout",
      "@build",
  
    ]
    
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
     
      "wikimedia/composer-merge-plugin": true
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Coolsam\\Modules\\ModulesServiceProvider"
      ],
      "aliases": {
        "FilamentModules": "FilamentModules"
      }
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
